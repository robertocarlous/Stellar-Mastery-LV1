{
  "name": "stellar-mastery-lv3",
  "version": "3.0.0",
  "description": "Stellar Mastery Level 3 — production-ready dApp with inter-contract Soroban, CI/CD, and tests",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "contract:build": "cd contracts && stellar contract build --out-dir .",
    "contract:test": "cd contracts && cargo test",
    "contract:deploy": "node scripts/deploy-contract.mjs"
  },
  "dependencies": {
    "@creit.tech/stellar-wallets-kit": "^2.3.0",
    "@stellar/freighter-api": "^4.1.0",
    "@stellar/stellar-sdk": "^16.0.1",
    "next": "14.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
    "vitest": "^2.1.0"
  }
}
